# ─── DataBlitz Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── USA ──────────────────────────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here          # https://fred.stlouisfed.org/docs/api/api_key.html
BLS_API_KEY=your_bls_api_key_here            # https://data.bls.gov/registrationEngine/
NOAA_CDO_TOKEN=your_noaa_token_here          # https://www.ncdc.noaa.gov/cdo-web/token

# ── UK ───────────────────────────────────────────────────────────────────────
# ONS Beta API: no key required
# Bank of England: no key required
# Met Office Hadley: no key required (flat file download)
# NHS England: no key required for open datasets

# ── India ─────────────────────────────────────────────────────────────────────
DATA_GOV_IN_KEY=your_data_gov_in_key_here    # https://data.gov.in/user/register
# World Bank API: no key required
# OpenAQ API: no key required (v3 open)

# ── AI Fallbacks ─────────────────────────────────────────────────────────────
# Primary: Puter.js (uses PUTER_AUTH_TOKEN above for both Claude AND Grok)
# Fallback 1 — Grok via Puter: no extra key, automatic
# Fallback 2 — Gemini 2.5 Flash-Lite (1000 free req/day):
#   Get key: aistudio.google.com → Create API key → free, just needs Google account
GEMINI_API_KEY=your_gemini_api_key_here
# BCB SGS API: no key required
# IBGE SIDRA API: no key required
# INPE PRODES: flat file download
# PAHO PLISA API: no key required

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_DB_PATH=./data/cache/datablitz.sqlite  # local SQLite stale cache
CACHE_TTL_HOURS=48                           # serve stale data for up to 48h on API failure
